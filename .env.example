LOG_LEVEL=INFO
ENVIRONMENT=local

RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
RABBITMQ_EXCHANGE=homeoffer.browse
RABBITMQ_DEAD_LETTER_EXCHANGE=homeoffer.browse.dlx
RABBITMQ_QUEUE=browse.jobs
RABBITMQ_ROUTING_KEY=browse

ALLOWED_BROWSE_HOST_SUFFIX=avito.ru
IDEMPOTENCY_SALT=change-me-in-production
IDEMPOTENCY_TTL_SECONDS=3600

SELENIUM_REMOTE_URL=http://selenium-hub:4444/wd/hub
SELENIUM_WAIT_TIMEOUT_SECONDS=20
SELENIUM_PAGE_LOAD_TIMEOUT_SECONDS=45
SELENIUM_STARTUP_TIMEOUT_SECONDS=90
HTML_LOG_CHUNK_SIZE=16000
REQUEUE_ON_FAILURE=false
